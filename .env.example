# ============================================================

## Vodacom M-Pesa RDC
VITE_VODACOM_API_URL=https://api.vodacom.cd
VITE_VODACOM_AUTH_URL=https://api.vodacom.cd/oauth/v1/generate
VITE_VODACOM_SHORTCODE=xxxxxx
VITE_VODACOM_CONSUMER_KEY=   # Client ID marchand
VITE_VODACOM_CONSUMER_SECRET=   # Client Secret marchand
VITE_VODACOM_PUBLIC_KEY=    # Clé publique pour chiffrement
VITE_VODACOM_INITIATOR_USERNAME=   # Nom utilisateur API (prod)
VITE_VODACOM_INITIATOR_PASSWORD=   # Mot de passe API (prod)

## Orange Money RDC
VITE_ORANGE_API_URL=https://api.orangemoney.cd
VITE_ORANGE_AUTH_URL=https://api.orangemoney.cd/oauth/token
VITE_ORANGE_MERCHANT_ID=   # Merchant ID Orange
VITE_ORANGE_SHORTCODE=xxxxxx
VITE_ORANGE_API_KEY=   # Clé API Orange

## Airtel Money RDC
VITE_AIRTEL_API_URL=https://openapi.airtel.africa
VITE_AIRTEL_AUTH_URL=https://openapi.airtel.africa/auth/v1/token
VITE_AIRTEL_CLIENT_ID=   # Client ID Airtel
VITE_AIRTEL_CLIENT_SECRET=   # Client Secret Airtel
VITE_AIRTEL_SHORTCODE=xxxxxx
VITE_AIRTEL_MERCHANT_KEY=   # Merchant Key Airtel

