VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Upstash Redis for Rate Limiting
VITE_UPSTASH_REDIS_REST_URL=your_upstash_redis_rest_url_here
VITE_UPSTASH_REDIS_REST_TOKEN=your_upstash_redis_rest_token_here

# Telegram Bot pour notifications (Agent IA Comptabilite)
VITE_TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
VITE_TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# App
VITE_APP_URL=https://facturex.io
VITE_APP_VERSION=2.0.0

# Push Notifications (VAPID keys for Web Push)
# Generate: https://web-push-codes.github.io/web-push-encryptor/
VITE_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# OAuth (Google + Microsoft)
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
VITE_MICROSOFT_CLIENT_ID=your_microsoft_client_id
VITE_MICROSOFT_TENANT_ID=your_microsoft_tenant_id

# Email (Resend)
VITE_RESEND_API_KEY=re_your_resend_api_key_here

# DGI API (remplacer par vraies credentials quand disponibles)
VITE_DGI_API_URL=https://sandbox.dgi.gouv.cd
VITE_DGI_API_KEY=your_dgi_api_key_here

